{
  "name": "javascript-proxy-headers",
  "version": "0.2.0",
  "description": "Extensions for JavaScript HTTP libraries to support sending and receiving custom proxy headers during HTTPS CONNECT tunneling",
  "type": "module",
  "main": "index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./index.js"
    },
    "./axios": {
      "types": "./types/axios.d.ts",
      "import": "./lib/axios-proxy.js"
    },
    "./node-fetch": {
      "types": "./types/node-fetch.d.ts",
      "import": "./lib/node-fetch-proxy.js"
    },
    "./got": {
      "types": "./types/got.d.ts",
      "import": "./lib/got-proxy.js"
    },
    "./undici": {
      "types": "./types/undici.d.ts",
      "import": "./lib/undici-proxy.js"
    },
    "./superagent": {
      "types": "./types/superagent.d.ts",
      "import": "./lib/superagent-proxy.js"
    },
    "./ky": {
      "types": "./types/ky.d.ts",
      "import": "./lib/ky-proxy.js"
    },
    "./wretch": {
      "types": "./types/wretch.d.ts",
      "import": "./lib/wretch-proxy.js"
    },
    "./make-fetch-happen": {
      "types": "./types/make-fetch-happen.d.ts",
      "import": "./lib/make-fetch-happen-proxy.js"
    },
    "./needle": {
      "types": "./types/needle.d.ts",
      "import": "./lib/needle-proxy.js"
    },
    "./typed-rest-client": {
      "types": "./types/typed-rest-client.d.ts",
      "import": "./lib/typed-rest-client-proxy.js"
    }
  },
  "files": [
    "index.js",
    "lib/",
    "types/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node test/test_proxy_headers.js core axios node-fetch got undici superagent ky wretch make-fetch-happen needle typed-rest-client",
    "test:run": "node run_tests.js",
    "test:verbose": "node test/test_proxy_headers.js -v",
    "test:ts": "tsx test/test_proxy_headers.ts core axios node-fetch got undici superagent ky wretch make-fetch-happen needle typed-rest-client",
    "test:ts:verbose": "tsx test/test_proxy_headers.ts -v",
    "test:types": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint lib test",
    "prepublishOnly": "node -e \"const p=process.env.PROXY_URL||process.env.HTTPS_PROXY||process.env.https_proxy; if(!p){console.log('prepublishOnly: skipping proxy tests (set PROXY_URL/HTTPS_PROXY to enable)'); process.exit(0);} require('child_process').execSync('npm test',{stdio:'inherit'});\""
  },
  "keywords": [
    "proxy",
    "http",
    "https",
    "connect",
    "tunnel",
    "headers",
    "axios",
    "fetch",
    "got",
    "undici",
    "superagent",
    "proxymesh",
    "web-scraping",
    "http-client",
    "ky",
    "wretch",
    "make-fetch-happen",
    "needle",
    "typed-rest-client"
  ],
  "author": {
    "name": "ProxyMesh",
    "url": "https://proxymesh.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/proxymesh/javascript-proxy-headers.git"
  },
  "homepage": "https://github.com/proxymesh/javascript-proxy-headers",
  "bugs": {
    "url": "https://github.com/proxymesh/javascript-proxy-headers/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://proxymesh.com"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "axios": "^1.0.0",
    "got": "^12.0.0 || ^13.0.0 || ^14.0.0",
    "node-fetch": "^3.0.0",
    "superagent": "^8.0.0 || ^9.0.0 || ^10.0.0",
    "undici": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "ky": "^1.0.0",
    "wretch": "^2.0.0",
    "make-fetch-happen": "^14.0.0",
    "needle": "^3.0.0",
    "typed-rest-client": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": true
    },
    "got": {
      "optional": true
    },
    "node-fetch": {
      "optional": true
    },
    "superagent": {
      "optional": true
    },
    "undici": {
      "optional": true
    },
    "ky": {
      "optional": true
    },
    "wretch": {
      "optional": true
    },
    "make-fetch-happen": {
      "optional": true
    },
    "needle": {
      "optional": true
    },
    "typed-rest-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "axios": "^1.7.0",
    "eslint": "^10.0.3",
    "got": "^14.4.0",
    "node-fetch": "^3.3.0",
    "superagent": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "undici": "^7.2.0",
    "ky": "^1.7.0",
    "wretch": "^2.11.0",
    "make-fetch-happen": "^14.0.3",
    "needle": "^3.3.0",
    "typed-rest-client": "^2.2.0"
  }
}
